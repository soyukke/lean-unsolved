  "verification_4_algebraic_structure": {
    "1": {
      "K": 1,
      "linear_part_consistent": true,
      "inverse_consistent": true,
      "proof_sketch": "(3R+1) mod 3^1 = (3(R mod 3^1)+1) mod 3^1 because 3*(R - R mod 3^1) = 3 * 3^1 * t ≡ 0 (mod 3^1). Also 2^{-j} mod 3^1 is the projection of 2^{-j} mod 3^2.",
      "formalization_approach": "Split into two lemmas: (1) (3R+1) % 3^K = (3*(R%3^K)+1) % 3^K  [omega or Nat.add_mul_mod_self] (2) pow(2,j,3^{K+1})^{-1} % 3^K = pow(2,j,3^K)^{-1}  [ZMod.castHom compatibility]"
    },
    "2": {
      "K": 2,
      "linear_part_consistent": true,
      "inverse_consistent": true,
      "proof_sketch": "(3R+1) mod 3^2 = (3(R mod 3^2)+1) mod 3^2 because 3*(R - R mod 3^2) = 3 * 3^2 * t ≡ 0 (mod 3^2). Also 2^{-j} mod 3^2 is the projection of 2^{-j} mod 3^3.",
      "formalization_approach": "Split into two lemmas: (1) (3R+1) % 3^K = (3*(R%3^K)+1) % 3^K  [omega or Nat.add_mul_mod_self] (2) pow(2,j,3^{K+1})^{-1} % 3^K = pow(2,j,3^K)^{-1}  [ZMod.castHom compatibility]"
    },
    "3": {
      "K": 3,
      "linear_part_consistent": true,
      "inverse_consistent": true,
      "proof_sketch": "(3R+1) mod 3^3 = (3(R mod 3^3)+1) mod 3^3 because 3*(R - R mod 3^3) = 3 * 3^3 * t ≡ 0 (mod 3^3). Also 2^{-j} mod 3^3 is the projection of 2^{-j} mod 3^4.",
      "formalization_approach": "Split into two lemmas: (1) (3R+1) % 3^K = (3*(R%3^K)+1) % 3^K  [omega or Nat.add_mul_mod_self] (2) pow(2,j,3^{K+1})^{-1} % 3^K = pow(2,j,3^K)^{-1}  [ZMod.castHom compatibility]"
    },
    "4": {
      "K": 4,
      "linear_part_consistent": true,
      "inverse_consistent": true,
      "proof_sketch": "(3R+1) mod 3^4 = (3(R mod 3^4)+1) mod 3^4 because 3*(R - R mod 3^4) = 3 * 3^4 * t ≡ 0 (mod 3^4). Also 2^{-j} mod 3^4 is the projection of 2^{-j} mod 3^5.",
      "formalization_approach": "Split into two lemmas: (1) (3R+1) % 3^K = (3*(R%3^K)+1) % 3^K  [omega or Nat.add_mul_mod_self] (2) pow(2,j,3^{K+1})^{-1} % 3^K = pow(2,j,3^K)^{-1}  [ZMod.castHom compatibility]"
    }
  },
